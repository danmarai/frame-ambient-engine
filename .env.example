# Frame Ambient Engine - Environment Variables
# Copy this file to .env.local and fill in your values.

# ============================================================
# REQUIRED
# ============================================================

# Session encryption secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET="your-session-secret-min-32-chars-long"

# Bcrypt hash of the operator password
# Generate with: npx bcryptjs-cli hash "your-password"
# Or use the setup script: pnpm run setup:password
APP_PASSWORD_HASH="$2b$10$your-bcrypt-hash-here"

# ============================================================
# SAMSUNG FRAME TV
# ============================================================

# IP address of your Samsung Frame TV (same network required)
# Find via: TV Settings > General > Network > Network Status
SAMSUNG_TV_IP=""

# Auth token (auto-populated after first connection approval)
SAMSUNG_TV_TOKEN=""

# ============================================================
# IMAGE GENERATION (optional - uses mock provider if empty)
# ============================================================

# OpenAI API key (for DALL-E image generation)
OPENAI_API_KEY=""

# Google Gemini API key (for Imagen generation)
GEMINI_API_KEY=""

# Active image provider: mock | openai | gemini
IMAGE_PROVIDER="mock"

# ============================================================
# WEATHER (optional - uses mock provider if empty)
# ============================================================

# Open-Meteo is free and requires no API key.
# These are used for default location if not set in the UI.
DEFAULT_LATITUDE=""
DEFAULT_LONGITUDE=""

# ============================================================
# DATABASE
# ============================================================

# SQLite database path (relative to apps/web)
DATABASE_URL="file:../../data/frame.db"
