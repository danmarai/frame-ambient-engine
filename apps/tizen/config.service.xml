<?xml version="1.0" encoding="UTF-8"?>
<!--
  Config variant for Tizen 6.0+ (2021+ Frame TVs).
  Includes background service for persistent cloud connection.
  DO NOT use on Tizen 5.5 (2020 TVs) — service element is ignored/crashes.

  To build for newer TVs:
    cp config.service.xml config.xml
    Then rebuild the .wgt package.
-->
<widget xmlns="http://www.w3.org/ns/widgets" xmlns:tizen="http://tizen.org/ns/widgets" id="http://frame-ambient.com/app" version="0.2.0" viewmodes="maximized">
    <tizen:application id="FrmeTst001.FrameArt" package="FrmeTst001" required_version="6.0"/>
    <tizen:profile name="tv"/>
    <content src="index.html"/>
    <icon src="icon.png"/>
    <name>Curateur</name>
    <tizen:privilege name="http://tizen.org/privilege/internet"/>
    <tizen:privilege name="http://tizen.org/privilege/alarm"/>
    <access origin="*" subdomains="true"/>
    <tizen:service id="FrmeTst001.FrameArt.service" auto-restart="true" on-boot="false">
        <tizen:content src="service/service.js"/>
        <tizen:name>Curateur Service</tizen:name>
        <tizen:icon src="icon.png"/>
        <tizen:description>Background service for art sync</tizen:description>
    </tizen:service>
</widget>
